{
  "name": "pokemon-tower-defense",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "data:generate": "node tools/generate-pokemon-data.mjs",
    "data:check": "vitest run tests/generator.test.ts tests/species.test.ts tests/sprites.test.ts",
    "sprites:download": "node tools/download-sprites.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.39.5",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
